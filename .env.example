# Copy this file to .env and fill in real values for local development.
# Never commit the actual .env file.

# SQLite file path (default). For Postgres/MySQL, use the appropriate connection string instead, e.g.:
# postgresql://user:password@localhost:5432/internship_db
DATABASE_URL="file:./dev.db"

# Secret used to sign JWTs. Must be at least 16 characters.
# Generate one locally, e.g.: openssl rand -base64 32
JWT_SECRET="replace-with-a-long-random-string"

# How long issued JWTs remain valid.
JWT_EXPIRES_IN="1d"

# Port the NestJS app listens on.
PORT=3000